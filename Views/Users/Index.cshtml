@model IEnumerable<SystemZglaszaniaUsterek.Models.Entities.UserModel>

@{
    ViewData["Title"] = "Użytkownicy";
}

<h1 class="mb-4">Lista użytkowników</h1>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Nazwa użytkownika</th>
            <th>Email</th>
            <th>Imię i nazwisko</th>
            <th>Rola</th>
            <th>Data utworzenia</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Username)</td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                <td>@(item.FirstName + " " + item.LastName)</td>
                <td>@Html.DisplayFor(modelItem => item.Role)</td>
                <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                <td>
                    <a asp-action="EditRole" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Zmień Rolę</a>
                </td>
            </tr>
        }
    </tbody>
</table>
