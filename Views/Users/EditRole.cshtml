@model SystemZglaszaniaUsterek.Models.ViewModels.EditUserRoleViewModel
@using SystemZglaszaniaUsterek.Models.Enums

@{
    ViewData["Title"] = "Edycja Roli";
}

<div class="form-page-container">
    <div class="container">

        <div class="form-page-header">
            <h1 class="form-page-title">Edytuj rolę użytkownika</h1>
            <p class="form-page-subtitle">Zmień uprawnienia przypisane do konta</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4">
                <div class="form-card">
                    <form asp-action="EditRole" method="post">
                        <input type="hidden" asp-for="UserId" />

                        <div class="form-group mb-3">
                            <label class="form-label">Użytkownik</label>
                            <input asp-for="Username" class="form-control" readonly />
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Role" class="form-label"></label>
                            <select asp-for="Role" asp-items="Html.GetEnumSelectList<Role>()" class="form-select"></select>
                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn-submit-ticket">Zapisz zmiany</button>
                            <a asp-action="Index" class="btn-cancel-ticket">Powrót</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
