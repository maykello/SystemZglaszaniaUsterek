@model SystemZglaszaniaUsterek.Models.ViewModels.EditUserRoleViewModel
@using SystemZglaszaniaUsterek.Models.Enums

@{
    ViewData["Title"] = "Edycja Roli";
}

<h1 class="mb-4">Edytuj rolę użytkownika</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="EditRole" method="post">
            <input type="hidden" asp-for="UserId" />
            <div class="form-group mb-3">
                <label class="control-label fw-bold">Użytkownik</label>
                <input asp-for="Username" class="form-control" readonly />
            </div>
            <div class="form-group mb-4">
                <label asp-for="Role" class="control-label fw-bold"></label>
                <select asp-for="Role" asp-items="Html.GetEnumSelectList<Role>()" class="form-select"></select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Zapisz zmiany" class="btn btn-success me-2" />
                <a asp-action="Index" class="btn btn-secondary">Powrót do listy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
