@model SystemZglaszaniaUsterek.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Przypomnienie hasła";
}

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h1 class="login-title">Przypomnienie hasła</h1>
            <p class="login-subtitle">Wyślemy nowe hasło na podany adres e-mail</p>
        </div>

        @if (TempData["ForgotPasswordMessage"] is string okMsg)
        {
            <div class="alert alert-success" role="alert">@okMsg</div>
        }

        <form asp-action="ForgotPassword" method="post" class="login-form">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                <strong>Błąd!</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Email" class="form-label">Adres e-mail</label>
                <input asp-for="Email" class="form-control form-control-lg" placeholder="np. uzytkownik@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
                <small class="form-text text-muted">
                    Podaj e-mail powiązany z Twoim kontem. Jeśli istnieje, wyślemy na niego nowe hasło.
                </small>
            </div>

            <div class="d-grid gap-2 mb-3">
                <button type="submit" class="btn btn-login btn-lg">Wyślij nowe hasło</button>
            </div>

            <div class="text-center">
                <a asp-action="Login" class="btn btn-link-light">Wróć do logowania</a>
            </div>
        </form>
    </div>

    <div class="login-background-decoration"></div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
