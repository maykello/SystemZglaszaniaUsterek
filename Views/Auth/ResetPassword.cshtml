@model SystemZglaszaniaUsterek.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Ustaw nowe hasło";
    var tokenInvalid = ViewData["TokenInvalid"] as bool? == true;
}

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h1 class="login-title">Ustaw nowe hasło</h1>
            <p class="login-subtitle">
                @if (tokenInvalid)
                {
                    <text>Link jest nieprawidłowy lub wygasł</text>
                }
                else
                {
                    <text>Wpisz nowe hasło dla swojego konta</text>
                }
            </p>
        </div>

        @if (tokenInvalid)
        {
            <div class="alert alert-danger" role="alert">
                Ten link do resetu hasła jest niepoprawny, został już użyty albo wygasł.
                Wróć do <a asp-action="ForgotPassword">formularza przypomnienia hasła</a>, żeby otrzymać nowy.
            </div>
            <div class="text-center">
                <a asp-action="Login" class="btn btn-link-light">Wróć do logowania</a>
            </div>
        }
        else
        {
            <form asp-action="ResetPassword" method="post" class="login-form">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Błąd!</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>

                <input type="hidden" asp-for="Token" />

                <div class="form-group mb-3">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" class="form-control form-control-lg" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control form-control-lg" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2 mb-3">
                    <button type="submit" class="btn btn-login btn-lg">Zapisz nowe hasło</button>
                </div>

                <div class="text-center">
                    <a asp-action="Login" class="btn btn-link-light">Wróć do logowania</a>
                </div>
            </form>
        }
    </div>

    <div class="login-background-decoration"></div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
