@model SystemZglaszaniaUsterek.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Logowanie";
}

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h1 class="login-title">System Zgłaszania Usterek</h1>
            <p class="login-subtitle">Zaloguj się do swojego konta</p>
        </div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="login-form">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                <strong>Błąd logowania!</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Username" class="form-label">Nazwa użytkownika</label>
                <input asp-for="Username" class="form-control form-control-lg" placeholder="Wpisz swoją nazwę użytkownika" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password" class="form-label">Hasło</label>
                <input asp-for="Password" class="form-control form-control-lg" placeholder="Wpisz swoje hasło" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="text-end mb-4">
                <a href="#" class="forgot-password-link">Zapomniałeś hasła?</a>
            </div>

            <div class="d-grid gap-2 mb-4">
                <button type="submit" class="btn btn-login btn-lg">Zaloguj się</button>
            </div>

            <div class="divider mb-4">
                <span>lub</span>
            </div>

            <div class="text-center">
                <p class="text-muted mb-0">Wróć do strony głównej</p>
                <a href="/" class="btn btn-link-light">Strona Główna</a>
            </div>
        </form>
    </div>

    <div class="login-background-decoration"></div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
