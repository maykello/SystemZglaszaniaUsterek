@model SystemZglaszaniaUsterek.Models.ViewModels.TicketListResultViewModel
@using SystemZglaszaniaUsterek.Models.ViewModels
@{
    ViewData["Title"] = "Zgłoszenia";
    var role = User.IsInRole("Administrator") ? "Administrator"
             : User.IsInRole("Technician") ? "Technician" : "User";

    string BuildQuery(int page, string? sortBy, bool sortDesc)
    {
        return $"?Scope={Model.Filter.Scope}&StatusId={Model.Filter.StatusId}&PriorityId={Model.Filter.PriorityId}&CategoryId={Model.Filter.CategoryId}" +
               $"&DateFrom={Model.Filter.DateFrom?.ToString("yyyy-MM-dd")}&DateTo={Model.Filter.DateTo?.ToString("yyyy-MM-dd")}&Search={Uri.EscapeDataString(Model.Filter.Search ?? "")}" +
               $"&SortBy={sortBy}&SortDesc={sortDesc.ToString().ToLowerInvariant()}&Page={page}&PageSize={Model.PageSize}";
    }

    string SortUrl(string column)
    {
        var nextDesc = Model.Filter.SortBy == column && !Model.Filter.SortDesc;
        return BuildQuery(1, column, nextDesc);
    }

    string SortArrowClass(string column)
        => Model.Filter.SortBy != column ? "" : Model.Filter.SortDesc ? "sort-desc" : "sort-asc";
}

<div class="tickets-container">
    <div class="container-fluid">

        <div class="tickets-page-header">
            <h1 class="tickets-page-title">Zgłoszenia</h1>
        </div>

        @if (TempData["TicketActionMessage"] is string okMsg)
        {
            <div class="alert alert-success">@okMsg</div>
        }
        @if (TempData["TicketActionError"] is string errMsg)
        {
            <div class="alert alert-danger">@errMsg</div>
        }

        <div class="filter-card">
            <form method="get">
                <div class="row g-2 align-items-end">
                    @if (role != "User")
                    {
                        <div class="col-md-2">
                            <label class="form-label">Zakres</label>
                            <select name="Scope" class="form-select">
                                <option value="@TicketScope.Mine" selected="@(Model.Filter.Scope == TicketScope.Mine)">Moje zgłoszenia</option>
                                <option value="@TicketScope.Assigned" selected="@(Model.Filter.Scope == TicketScope.Assigned)">Przydzielone do mnie</option>
                                <option value="@TicketScope.All" selected="@(Model.Filter.Scope == TicketScope.All)">Wszystkie</option>
                            </select>
                        </div>
                    }
                    <div class="col-md-2">
                        <label class="form-label">Status</label>
                        <select name="StatusId" class="form-select">
                            <option value="">-- dowolny --</option>
                            @foreach (var s in Model.Statuses)
                            {
                                <option value="@s.Id" selected="@(Model.Filter.StatusId == s.Id)">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Priorytet</label>
                        <select name="PriorityId" class="form-select">
                            <option value="">-- dowolny --</option>
                            @foreach (var p in Model.Priorities)
                            {
                                <option value="@p.Id" selected="@(Model.Filter.PriorityId == p.Id)">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Kategoria</label>
                        <select name="CategoryId" class="form-select">
                            <option value="">-- dowolna --</option>
                            @foreach (var c in Model.Categories)
                            {
                                <option value="@c.Id" selected="@(Model.Filter.CategoryId == c.Id)">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Od</label>
                        <input type="date" name="DateFrom" value="@(Model.Filter.DateFrom?.ToString("yyyy-MM-dd"))" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Do</label>
                        <input type="date" name="DateTo" value="@(Model.Filter.DateTo?.ToString("yyyy-MM-dd"))" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Szukaj</label>
                        <input type="text" name="Search" value="@Model.Filter.Search" class="form-control" placeholder="tytuł lub opis" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-login w-100">Filtruj</button>
                    </div>
                    <div class="col-md-2">
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">Wyczyść</a>
                    </div>
                </div>
            </form>
        </div>

        <p class="tickets-count">Łącznie: <strong>@Model.TotalCount</strong> zgłoszeń</p>

        <div class="tickets-table-wrapper">
            <div class="table-responsive">
                <table class="tickets-table">
                    <thead>
                        <tr>
                            <th><a class="sort-link sortable-th @SortArrowClass("Id")" href="@SortUrl("Id")">#<span class="sort-arrow"></span></a></th>
                            <th><a class="sort-link sortable-th @SortArrowClass("Title")" href="@SortUrl("Title")">Tytuł<span class="sort-arrow"></span></a></th>
                            <th><a class="sort-link sortable-th @SortArrowClass("Category")" href="@SortUrl("Category")">Kategoria<span class="sort-arrow"></span></a></th>
                            <th><a class="sort-link sortable-th @SortArrowClass("Priority")" href="@SortUrl("Priority")">Priorytet<span class="sort-arrow"></span></a></th>
                            <th><a class="sort-link sortable-th @SortArrowClass("Status")" href="@SortUrl("Status")">Status<span class="sort-arrow"></span></a></th>
                            <th><a class="sort-link sortable-th @SortArrowClass("Reporter")" href="@SortUrl("Reporter")">Zgłaszający<span class="sort-arrow"></span></a></th>
                            <th><a class="sort-link sortable-th @SortArrowClass("Technician")" href="@SortUrl("Technician")">Technik<span class="sort-arrow"></span></a></th>
                            <th><a class="sort-link sortable-th @SortArrowClass("CreatedAt")" href="@SortUrl("CreatedAt")">Utworzono<span class="sort-arrow"></span></a></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Items)
                        {
                            <tr>
                                <td data-label="#"><span class="ticket-id-cell">@t.Id</span></td>
                                <td data-label="Tytuł"><span class="ticket-title-cell">@t.Title</span></td>
                                <td data-label="Kategoria">@t.CategoryName</td>
                                <td data-label="Priorytet">@(t.PriorityName ?? "-")</td>
                                <td data-label="Status">
                                    <span class="badge @(t.IsClosed ? "bg-success" : t.StatusName == "Nowe" ? "bg-danger" : "bg-warning text-dark")">@t.StatusName</span>
                                </td>
                                <td data-label="Zgłaszający">@(t.ReporterUsername ?? "-")</td>
                                <td data-label="Technik">@(t.TechnicianUsername ?? "-")</td>
                                <td data-label="Utworzono">@t.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td data-label="Akcje">
                                    <a asp-action="Details" asp-route-id="@t.Id" class="btn-action btn-action-role">Szczegóły</a>
                                </td>
                            </tr>
                        }
                        @if (Model.Items.Count == 0)
                        {
                            <tr>
                                <td colspan="9">
                                    <div class="empty-users-state">
                                        <p>Brak zgłoszeń pasujących do filtrów.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="tickets-footer">
                @if (Model.TotalPages > 1)
                {
                    <nav>
                        <ul class="pagination-custom">
                            @foreach (var p in PaginationHelper.GetPageItems(Model.Page, Model.TotalPages))
                            {
                                if (p is null)
                                {
                                    <li class="page-item page-ellipsis"><span class="page-link">&hellip;</span></li>
                                }
                                else
                                {
                                    <li class="page-item @(p == Model.Page ? "active" : "")">
                                        <a class="page-link" href="@BuildQuery(p.Value, Model.Filter.SortBy, Model.Filter.SortDesc)">@p</a>
                                    </li>
                                }
                            }
                        </ul>
                    </nav>
                }
                else
                {
                    <div></div>
                }
                <a asp-action="Create" class="btn-add-user">+ Nowe zgłoszenie</a>
            </div>
        </div>

    </div>
</div>
