@model SystemZglaszaniaUsterek.Models.ViewModels.TicketDetailsViewModel
@{
    ViewData["Title"] = $"Zgłoszenie #{Model.Id}";
}

<a asp-action="Index" class="btn btn-link mb-3">&larr; Powrót do listy</a>

@if (TempData["TicketActionMessage"] is string okMsg)
{
    <div class="alert alert-success">@okMsg</div>
}
@if (TempData["TicketActionError"] is string errMsg)
{
    <div class="alert alert-danger">@errMsg</div>
}

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h2 class="mb-1">#@Model.Id - @Model.Title</h2>
                <p class="text-muted mb-2">
                    Zgłoszone przez <strong>@(Model.ReporterUsername ?? "-")</strong>
                    @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                </p>
            </div>
            <div>
                <span class="badge @(Model.IsClosed ? "bg-success" : "bg-warning text-dark") fs-6">@Model.StatusName</span>
            </div>
        </div>

        <dl class="row mt-3">
            <dt class="col-sm-3">Kategoria</dt>
            <dd class="col-sm-9">@Model.CategoryName</dd>

            <dt class="col-sm-3">Priorytet</dt>
            <dd class="col-sm-9">@(Model.PriorityName ?? "-")</dd>

            <dt class="col-sm-3">Lokalizacja</dt>
            <dd class="col-sm-9">@(Model.Location ?? "-")</dd>

            <dt class="col-sm-3">Technik</dt>
            <dd class="col-sm-9">@(Model.TechnicianUsername ?? "(nieprzydzielony)")</dd>

            <dt class="col-sm-3">Ostatnia zmiana</dt>
            <dd class="col-sm-9">@(Model.UpdatedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "-")</dd>
        </dl>

        <h4>Opis</h4>
        <p class="text-pre-wrap">@Model.Description</p>

        @if (Model.Attachments.Count > 0)
        {
            <h4 class="mt-4">Załączniki</h4>
            <ul>
                @foreach (var a in Model.Attachments)
                {
                    <li><a href="@a.Url" target="_blank" rel="noopener">@a.OriginalFileName</a> (@(a.ContentType), @((a.SizeBytes / 1024.0 / 1024.0).ToString("F2")) MB)</li>
                }
            </ul>
        }
    </div>
</div>

@if (Model.CanChangeStatus || Model.CanAssignTechnician || Model.CanSelfAssign)
{
    <div class="card mb-3">
        <div class="card-body">
            <h4>Akcje</h4>

            @if (Model.CanChangeStatus)
            {
                <form asp-action="ChangeStatus" asp-route-id="@Model.Id" method="post" class="row g-2 align-items-end mb-2">
                    @Html.AntiForgeryToken()
                    <div class="col-auto">
                        <label class="form-label">Zmień status</label>
                        <select name="statusId" class="form-select">
                            @foreach (var s in Model.AvailableStatuses)
                            {
                                <option value="@s.Id" selected="@(Model.StatusId == s.Id)">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">Zapisz status</button>
                    </div>
                </form>

                <form asp-action="ChangePriority" asp-route-id="@Model.Id" method="post" class="row g-2 align-items-end mb-2">
                    @Html.AntiForgeryToken()
                    <div class="col-auto">
                        <label class="form-label">Zmień priorytet</label>
                        <select name="priorityId" class="form-select">
                            @foreach (var p in Model.AvailablePriorities)
                            {
                                <option value="@p.Id" selected="@(Model.PriorityId == p.Id)">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">Zapisz priorytet</button>
                    </div>
                </form>
            }

            @if (Model.CanAssignTechnician)
            {
                <form asp-action="Assign" asp-route-id="@Model.Id" method="post" class="row g-2 align-items-end mb-2">
                    @Html.AntiForgeryToken()
                    <div class="col-auto">
                        <label class="form-label">Przydziel technika</label>
                        <select name="technicianId" class="form-select">
                            <option value="">(brak)</option>
                            @foreach (var u in Model.AvailableTechnicians)
                            {
                                <option value="@u.Id" selected="@(Model.TechnicianId == u.Id)">@u.Username (@u.Role)</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">Przydziel</button>
                    </div>
                </form>
            }
            else if (Model.CanSelfAssign)
            {
                @if (Model.TechnicianId == null)
                {
                    <form asp-action="Assign" asp-route-id="@Model.Id" method="post" class="d-inline-block mb-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="technicianId" value="@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)" />
                        <button type="submit" class="btn btn-success">Przydziel mnie do tego zgłoszenia</button>
                    </form>
                }
                else
                {
                    <form asp-action="Assign" asp-route-id="@Model.Id" method="post" class="d-inline-block mb-2"
                          onsubmit="return confirm('Zwolnić zgłoszenie? Inny technik będzie mógł je podjąć.');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-secondary">Zwolnij zgłoszenie</button>
                    </form>
                }
            }
        </div>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <h4>Komentarze</h4>

        @if (Model.Comments.Count == 0)
        {
            <p class="text-muted">Brak komentarzy.</p>
        }
        else
        {
            foreach (var c in Model.Comments)
            {
                <div class="border-start border-3 ps-3 mb-3">
                    <div class="text-muted small">
                        <strong>@(c.AuthorUsername ?? "-")</strong>
                        @c.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                    </div>
                    <div class="text-pre-wrap">@c.Content</div>
                </div>
            }
        }

        @if (Model.CanComment)
        {
            <form asp-action="AddComment" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TicketId" value="@Model.Id" />
                <div class="form-group mb-2">
                    <label for="commentContent" class="form-label">Dodaj komentarz</label>
                    <textarea id="commentContent" name="Content" class="form-control" rows="3" maxlength="2000" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Wyślij</button>
            </form>
        }
        else if (Model.IsClosed)
        {
            <div class="alert alert-secondary mt-3 mb-0">Zgłoszenie jest zamknięte. Dodawanie komentarzy jest zablokowane.</div>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h4>Historia zmian statusu</h4>
        @if (Model.History.Count == 0)
        {
            <p class="text-muted">Brak wpisów.</p>
        }
        else
        {
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Z</th>
                        <th>Na</th>
                        <th>Przez</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in Model.History)
                    {
                        <tr>
                            <td>@h.ChangedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(h.OldStatusName ?? "-")</td>
                            <td>@(h.NewStatusName ?? "-")</td>
                            <td>@(h.ChangedByUsername ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<style>
    .text-pre-wrap { white-space: pre-wrap; }
</style>
