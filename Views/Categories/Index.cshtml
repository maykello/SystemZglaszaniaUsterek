@model IEnumerable<SystemZglaszaniaUsterek.Models.Entities.CategoryModel>
@{
    ViewData["Title"] = "Kategorie";
}

<h1 class="mb-3">Kategorie usterek</h1>

@if (TempData["CategoriesMessage"] is string okMsg)
{
    <div class="alert alert-success">@okMsg</div>
}
@if (TempData["CategoriesError"] is string errMsg)
{
    <div class="alert alert-danger">@errMsg</div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">+ Nowa kategoria</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>Nazwa</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Id</td>
                <td>@c.Name</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline" onsubmit="return confirm('Usunąć kategorię?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
