@model IEnumerable<SystemZglaszaniaUsterek.Models.Entities.AnnouncementModel>
@{
    ViewData["Title"] = "Ogłoszenia";
}

<div class="admin-panel-container">
    <div class="container">

        <div class="admin-panel-header">
            <div class="admin-header-top">
                <div>
                    <h1 class="admin-panel-title">Ogłoszenia systemowe</h1>
                    <p class="admin-panel-subtitle">Zarządzaj ogłoszeniami widocznymi dla użytkowników</p>
                </div>
                <a asp-action="Create" class="btn-add-user">+ Nowe ogłoszenie</a>
            </div>
        </div>

        @if (TempData["AnnouncementsMessage"] is string okMsg)
        {
            <div class="alert alert-success">@okMsg</div>
        }

        <div class="admin-panel-content">
            @if (!Model.Any())
            {
                <div class="empty-users-state">
                    <p>Brak ogłoszeń.</p>
                    <a asp-action="Create" class="btn-add-user-empty">+ Nowe ogłoszenie</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="data-table" data-sortable="true">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Tytuł</th>
                                <th>Ważność</th>
                                <th>Status</th>
                                <th>Utworzono</th>
                                <th>Autor</th>
                                <th class="text-end" data-no-sort="true">Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model)
                            {
                                <tr>
                                    <td data-label="#"><span class="user-date">@a.Id</span></td>
                                    <td data-label="Tytuł"><span class="user-username">@a.Title</span></td>
                                    <td data-label="Ważność">
                                        @switch (a.Severity)
                                        {
                                            case SystemZglaszaniaUsterek.Models.Enums.AnnouncementSeverity.Info:
                                                <span class="role-badge badge-info">Info</span>
                                                break;
                                            case SystemZglaszaniaUsterek.Models.Enums.AnnouncementSeverity.Warning:
                                                <span class="role-badge badge-warning">Ostrzeżenie</span>
                                                break;
                                            case SystemZglaszaniaUsterek.Models.Enums.AnnouncementSeverity.Critical:
                                                <span class="role-badge badge-critical">Krytyczne</span>
                                                break;
                                        }
                                    </td>
                                    <td data-label="Status">
                                        @if (a.IsActive)
                                        {
                                            <span class="role-badge badge-active">Aktywne</span>
                                        }
                                        else
                                        {
                                            <span class="role-badge badge-inactive">Nieaktywne</span>
                                        }
                                    </td>
                                    <td data-label="Utworzono"><span class="user-date">@a.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span></td>
                                    <td data-label="Autor"><span class="user-name">@(a.CreatedBy?.Username ?? "-")</span></td>
                                    <td data-label="Akcje" class="text-end">
                                        <div class="action-buttons justify-content-end">
                                            <a asp-action="Edit" asp-route-id="@a.Id" class="btn-action btn-action-edit">Edytuj</a>
                                            <form asp-action="ToggleActive" asp-route-id="@a.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-action btn-action-role">
                                                    @(a.IsActive ? "Ukryj" : "Aktywuj")
                                                </button>
                                            </form>
                                            <form asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline" onsubmit="return confirm('Usunąć ogłoszenie? Tej operacji nie można cofnąć.');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-action btn-action-delete">Usuń</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>
