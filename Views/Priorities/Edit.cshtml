@model SystemZglaszaniaUsterek.Controllers.PriorityFormModel
@{
    ViewData["Title"] = "Edycja priorytetu";
}

<div class="form-page-container">
    <div class="container">

        <div class="form-page-header">
            <h1 class="form-page-title">Edycja priorytetu</h1>
            <p class="form-page-subtitle">Zaktualizuj nazwę poziomu priorytetu</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4">
                <div class="form-card">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-4">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn-submit-ticket">Zapisz zmiany</button>
                            <a asp-action="Index" class="btn-cancel-ticket">Anuluj</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
