@model IEnumerable<SystemZglaszaniaUsterek.Models.Entities.PriorityModel>
@{
    ViewData["Title"] = "Priorytety";
}

<h1 class="mb-3">Priorytety zgłoszeń</h1>

@if (TempData["PrioritiesMessage"] is string okMsg)
{
    <div class="alert alert-success">@okMsg</div>
}
@if (TempData["PrioritiesError"] is string errMsg)
{
    <div class="alert alert-danger">@errMsg</div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">+ Nowy priorytet</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>Nazwa</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.Name</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                    <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Usunąć priorytet?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
